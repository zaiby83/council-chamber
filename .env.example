# Shure SCM820 Mixer (optional - falls back to simulation if unreachable)
SHURE_IP=192.168.1.100
SHURE_PORT=2202

# Azure Cognitive Speech (optional - only needed for Azure transcription)
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=westus2

# Server Configuration
PORT=3001
NODE_ENV=development

# Meeting Display Info
CITY_NAME=City of Fairfield
CHAMBER_NAME=Council Chamber
