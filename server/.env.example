# Audio source: scm820 | zoom | simulation
AUDIO_SOURCE=scm820

# Shure SCM820 mixer — required when AUDIO_SOURCE=scm820
SHURE_IP=192.168.1.100
SHURE_PORT=2202

# Zoom webhooks — required when AUDIO_SOURCE=zoom
ZOOM_WEBHOOK_SECRET_TOKEN=your_webhook_secret
ZOOM_ACCOUNT_ID=your_account_id
ZOOM_CLIENT_ID=your_client_id
ZOOM_CLIENT_SECRET=your_client_secret
ZOOM_MEETING_ID=                # optional: filter to a specific meeting

# Azure Cognitive Speech — required for live transcription
AZURE_SPEECH_KEY=your_key_here
AZURE_SPEECH_REGION=westus2

# Server
PORT=3001

# Meeting display info
CITY_NAME=City of Fairfield
CHAMBER_NAME=Council Chamber
